# PostgreSQL + pgvector (docker-compose поднимает на хост-порту 5433)
DATABASE_URL="postgresql://baza:baza@localhost:5433/baza_bot?schema=public"

# bothub — OpenAI-совместимый прокси (LLM + эмбеддинги)
BOTHUB_API_KEY="your-bothub-jwt-here"
BOTHUB_BASE_URL="https://bothub.chat/api/v2/openai/v1"

# Soniox — STT (Часть 3, голосовые)
SONIOX_API_KEY="your-soniox-key-here"

# Telegram (Часть 2, живой бот)
TELEGRAM_BOT_TOKEN="your-botfather-token-here"
TELEGRAM_WEBHOOK_SECRET="random-secret-for-webhook"
